# ─── FEATURE TOGGLES ────────────────────────────────────────
ENABLE_SECURITY_2FA=false
ENABLE_RATE_LIMIT=true
ENABLE_AUDIT_LOG=true
ENABLE_ANTI_RAID=true
ENABLE_LINK_DETECTOR=true
ENABLE_SESSION_ENCRYPTION=true
ENABLE_IP_DETECTION=false
ENABLE_SOCIAL_BOOST=false
ENABLE_AUTO_BIO=false
ENABLE_AUTO_RECORDING=false
ENABLE_AUTO_ONLINE=false
ENABLE_ANTI_CALL=false
ENABLE_AUTO_READ=false

# ─── LARA AUTO FEATURES ─────────────────────────────────────
# Auto react to every incoming message with random emoji
ENABLE_AUTO_REACT=false
AUTO_REACT_EMOJIS=❤️,🩷,🧡,💛,💚,🩵,💙,💜

# Auto presence (typing/recording) shown before bot replies
ENABLE_AUTO_PRESENCE=false
# values: composing | recording | available | unavailable
AUTO_PRESENCE_TYPE=composing

# Auto block non-contacts who message bot in PM
ENABLE_AUTO_BLOCK=false

# Auto voice / sticker / text reply via triggers — managed via commands
ENABLE_AUTO_VOICE=false
ENABLE_AUTO_STICKER_REPLY=false
ENABLE_AUTO_REPLY=false

# Morocco block (+212 numbers)
ENABLE_MOROCCO_BLOCK=false

# ─── LIMITS ─────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20
COMMAND_COOLDOWN_MS=1000
WARN_LIMIT=3
AUTO_DELETE_SECS=330

# ─── TIMEZONE ───────────────────────────────────────────────
TIMEZONE=Asia/Colombo

# ─── NODE ENV ───────────────────────────────────────────────
NODE_ENV=production

